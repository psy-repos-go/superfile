---
import { ClientRouter } from "astro:transitions";

const enableAnalytics = import.meta.env.PROD;
---

<ClientRouter />

<script>
	let didSpaSwap = false;

	document.addEventListener("astro:before-swap", () => {
		didSpaSwap = true;
	});

	document.addEventListener("astro:page-load", () => {
		if (!didSpaSwap) return;
		didSpaSwap = false;

		document.querySelectorAll<HTMLScriptElement>('script[src="https://giscus.app/client.js"]').forEach(giscusScript => {
			const parent = giscusScript.parentElement;
			if (!parent || parent.querySelector(".giscus")) return;

			const freshScript = document.createElement("script");
			for (const attr of giscusScript.attributes) {
				freshScript.setAttribute(attr.name, attr.value);
			}
			giscusScript.replaceWith(freshScript);
		});
	});
</script>

<!-- Favicon -->
<link rel="icon" href="/logo.svg" type="image/svg+xml" />

<!-- Fonts -->
<link rel="preconnect" href="https://font.emtech.cc" />
<link rel="stylesheet" href="https://font.emtech.cc/css/GenSenRoundedTW" />
<link rel="stylesheet" href="https://font.emtech.cc/css/JetBrainsMono" />

<!-- Analytics -->
<script is:inline define:vars={{ enableAnalytics }}>
	if (enableAnalytics && ["superfile.dev", "www.superfile.dev"].includes(window.location.hostname)) {
		window.minimalAnalytics = { trackingId: "G-WFLBCRZ7MC", autoTrack: true };
	}
</script>
{enableAnalytics && <script async src="https://cdn.jsdelivr.net/npm/@minimal-analytics/ga4/dist/index.js" data-analytics="ga4" />}
{
	enableAnalytics && (
		<script defer src="https://umami.yorukot.me/script.js" data-website-id="8792ee93-9a4a-47be-9e7f-2b1587c3a3d1" data-domains="superfile.dev,www.superfile.dev" data-analytics="umami" />
	)
}
