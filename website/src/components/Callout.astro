---
import { Info, Lightbulb, OctagonAlert, TriangleAlert } from "@lucide/astro";

type CalloutType = "tip" | "caution" | "note" | "danger";

interface Props {
	type?: CalloutType;
}

const { type = "note" } = Astro.props;

const icons = {
	tip: Lightbulb,
	caution: TriangleAlert,
	note: Info,
	danger: OctagonAlert
};

const labels = {
	tip: "tip",
	caution: "caution",
	note: "note",
	danger: "danger"
};

const Icon = icons[type] ?? Info;
const label = labels[type] ?? "note";
---

<aside class={`doc-aside doc-aside--${type}`} data-type={type}>
	<span class="doc-aside-icon" aria-hidden="true">
		<Icon size={16} stroke-width={2.25} />
	</span>
	<span class="doc-aside-label">{label}</span>
	<slot />
</aside>
