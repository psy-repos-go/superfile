---
import logoDay from "../assets/superfile-day.svg";
import logoNight from "../assets/superfile-night.svg";
import SiteNav from "../components/SiteNav.astro";
import Landing from "../layouts/Landing.astro";
import "../styles/branding.css";

type Locale = "en" | "zh-tw";

interface Props {
	locale?: Locale;
}

const locale = Astro.props.locale ?? "en";
const isZhTw = locale === "zh-tw";
const prefix = isZhTw ? "/zh-tw" : "";
const homeHref = isZhTw ? "/zh-tw/" : "/";

const copy = {
	en: {
		title: "superfile branding",
		description: "Download the superfile logo and wordmark, plus quick naming guidance for references to the project.",
		nav: {
			docs: "Docs",
			github: "GitHub",
			discord: "Discord",
			getStarted: "get started",
			homeAria: "superfile home"
		},
		label: "// brand assets",
		headline: "Download the superfile logo",
		intro: "Use these assets when writing about superfile, showing the app in a project list, or linking to the community.",
		nameRule: "Write the project name as superfile, all lower case.",
		nameNote: "Avoid Superfile, SuperFile, or SUPERFILE unless you are quoting a source that already wrote it that way.",
		assetsTitle: "Logo downloads",
		assets: [
			{
				title: "App icon",
				description: "Standalone folder icon for avatars, lists, badges, and compact placements.",
				href: "/logo.svg",
				download: "superfile-logo.svg",
				preview: "/logo.svg",
				modifier: "brand-asset-preview--icon"
			},
			{
				title: "Wordmark for dark backgrounds",
				description: "Full superfile wordmark with light lettering for dark layouts.",
				href: logoNight.src,
				download: "superfile-wordmark-dark.svg",
				preview: logoNight.src,
				modifier: "brand-asset-preview--dark"
			},
			{
				title: "Wordmark for light backgrounds",
				description: "Full superfile wordmark with dark lettering for light layouts.",
				href: logoDay.src,
				download: "superfile-wordmark-light.svg",
				preview: logoDay.src,
				modifier: "brand-asset-preview--light"
			}
		],
		download: "Download SVG",
		usageTitle: "Usage notes",
		usage: [
			"Keep the logo proportions intact.",
			"Leave clear space around the mark so it does not touch nearby text or borders.",
			"Do not recolor, stretch, rotate, or add effects to the logo.",
			"Pair the logo with the lowercase name: superfile."
		],
		footer: {
			license: "MIT License",
			by: "by yorukot & contributors",
			docs: "Docs",
			branding: "Branding",
			github: "GitHub",
			discord: "Discord",
			changelog: "Changelog",
			install: "Install"
		}
	},
	"zh-tw": {
		title: "superfile 品牌資源",
		description: "下載 superfile 標誌與字標，並查看專案名稱的基本使用規範。",
		nav: {
			docs: "文件",
			github: "GitHub",
			discord: "Discord",
			getStarted: "開始使用",
			homeAria: "superfile 首頁"
		},
		label: "// 品牌資源",
		headline: "下載 superfile 標誌",
		intro: "撰寫 superfile 相關內容、整理專案清單，或連結到社群時，可以使用這些品牌資源。",
		nameRule: "專案名稱請寫成 superfile，全部使用小寫。",
		nameNote: "除非是在引用原文，否則請避免寫成 Superfile、SuperFile 或 SUPERFILE。",
		assetsTitle: "標誌下載",
		assets: [
			{
				title: "App 圖示",
				description: "獨立資料夾圖示，適合頭像、列表、徽章與小尺寸位置。",
				href: "/logo.svg",
				download: "superfile-logo.svg",
				preview: "/logo.svg",
				modifier: "brand-asset-preview--icon"
			},
			{
				title: "深色背景字標",
				description: "搭配淺色文字的完整 superfile 字標，適合深色版面。",
				href: logoNight.src,
				download: "superfile-wordmark-dark.svg",
				preview: logoNight.src,
				modifier: "brand-asset-preview--dark"
			},
			{
				title: "淺色背景字標",
				description: "搭配深色文字的完整 superfile 字標，適合淺色版面。",
				href: logoDay.src,
				download: "superfile-wordmark-light.svg",
				preview: logoDay.src,
				modifier: "brand-asset-preview--light"
			}
		],
		download: "下載 SVG",
		usageTitle: "使用提醒",
		usage: ["請維持標誌原本的比例。", "標誌周圍保留足夠留白，避免緊貼文字或邊框。", "請勿重新上色、拉伸、旋轉，或替標誌加上特效。", "搭配文字時，請使用全小寫名稱：superfile。"],
		footer: {
			license: "MIT 授權",
			by: "由 yorukot 與貢獻者共同維護",
			docs: "文件",
			branding: "品牌",
			github: "GitHub",
			discord: "Discord",
			changelog: "更新紀錄",
			install: "安裝"
		}
	}
}[locale];
---

<Landing title={copy.title} description={copy.description} lang={isZhTw ? "zh-TW" : "en"} canonicalPath={`${prefix}/branding`}>
	<SiteNav isZhTw={isZhTw} baseSlug="branding" labels={copy.nav} />

	<main class="branding-page">
		<section class="branding-hero" aria-labelledby="branding-title">
			<div class="branding-hero-copy">
				<span class="branding-label">{copy.label}</span>
				<h1 id="branding-title">{copy.headline}</h1>
				<p>{copy.intro}</p>
			</div>

			<aside class="brand-name-card" aria-label={copy.nameRule}>
				<p class="brand-name-card-kicker">naming</p>
				<p class="brand-name-card-name">superfile</p>
				<p class="brand-name-card-rule">{copy.nameRule}</p>
				<p class="brand-name-card-note">{copy.nameNote}</p>
			</aside>
		</section>

		<section class="brand-section" aria-labelledby="assets-title">
			<div class="brand-section-heading">
				<h2 id="assets-title">{copy.assetsTitle}</h2>
			</div>

			<div class="brand-assets-grid">
				{
					copy.assets.map(asset => (
						<article class="brand-asset-card">
							<div class={`brand-asset-preview ${asset.modifier}`}>
								<img src={asset.preview} alt={asset.title} loading="lazy" decoding="async" />
							</div>
							<div class="brand-asset-body">
								<h3>{asset.title}</h3>
								<p>{asset.description}</p>
								<a class="brand-download-link" href={asset.href} download={asset.download}>
									{copy.download}
								</a>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section class="brand-section brand-usage" aria-labelledby="usage-title">
			<div class="brand-section-heading">
				<h2 id="usage-title">{copy.usageTitle}</h2>
			</div>

			<ul>
				{copy.usage.map(item => <li>{item}</li>)}
			</ul>
		</section>
	</main>

	<footer class="branding-footer">
		<div class="branding-footer-inner">
			<div class="branding-footer-left">
				<a href={homeHref} class="branding-footer-brand">superfile</a>
				<span class="branding-footer-sep" aria-hidden="true">·</span>
				<span>{copy.footer.license}</span>
				<span class="branding-footer-sep" aria-hidden="true">·</span>
				<span>{copy.footer.by}</span>
			</div>
			<nav class="branding-footer-links" aria-label="Footer">
				<a href={`${prefix}/overview`}>{copy.footer.docs}</a>
				<a href={`${prefix}/branding`}>{copy.footer.branding}</a>
				<a href="https://github.com/yorukot/superfile" target="_blank" rel="noopener noreferrer">{copy.footer.github}</a>
				<a href="https://discord.gg/YYtJ23Du7B" target="_blank" rel="noopener noreferrer">{copy.footer.discord}</a>
				<a href={`${prefix}/changelog`}>{copy.footer.changelog}</a>
				<a href={`${prefix}/getting-started/installation`}>{copy.footer.install}</a>
			</nav>
		</div>
	</footer>
</Landing>
